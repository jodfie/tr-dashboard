# tr-engine connection for Vite dev proxy (base URL, no path)
# Required to enable the dev proxy; omit if using VITE_API_BASE for direct connection.
# Example: TR_ENGINE_URL=http://localhost:3000
TR_ENGINE_URL=

# Frontend API base URL (including /api/v1 path)
# Default: /api/v1 (relative, requires proxy or reverse proxy like Caddy)
# Set to an absolute URL to connect directly without a proxy:
# Example: VITE_API_BASE=http://localhost:3000/api/v1
VITE_API_BASE=

# Disable the built-in update check (set to "true" to disable)
VITE_DISABLE_UPDATE_CHECK=

# tr-engine API authentication token (Bearer token)
# Only required if your tr-engine instance has AUTH_TOKEN enabled.
# Leave blank or omit entirely for instances without auth.
TR_AUTH_TOKEN=
